# Local defaults work without this file.
# For Supabase, use the pooled connection string and keep sslmode=require.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Vercel Services mounts the FastAPI backend at /backend.
# Leave unset on Vercel unless you deploy frontend/backend as separate projects.
NEXT_PUBLIC_API_URL=

# Comma-separated list for direct browser calls to the backend in local/separate-service deploys.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-project.vercel.app

# Optional protected manual sync endpoint: POST /backend/admin/sync with X-Sync-Token.
ADMIN_SYNC_ENABLED=false
SYNC_TOKEN=replace-with-a-long-random-string

# Serverless deployments should avoid holding SQLAlchemy connections open.
DISABLE_DB_POOL=true
