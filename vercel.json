{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/backend",
      "framework": "fastapi",
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": [
        "backend/app/**",
        "backend/main.py",
        "backend/requirements.txt",
        "scripts/**"
      ],
      "excludeFiles": [
        "data/forecast.db",
        "backend/app/data/forecast.db",
        "frontend/**",
        "**/__pycache__/**",
        "**/*.pyc"
      ]
    }
  },
  "crons": [
    {
      "path": "/backend/admin/cron/sync",
      "schedule": "*/10 16-23 * * *"
    },
    {
      "path": "/backend/admin/cron/sync",
      "schedule": "*/10 0-5 * * *"
    },
    {
      "path": "/backend/admin/cron/sync",
      "schedule": "0,10,20,30 6 * * *"
    }
  ]
}
